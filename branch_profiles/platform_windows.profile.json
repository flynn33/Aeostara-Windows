{
  "profile": "platform_windows",
  "description": "Windows native realization branch profile",
  "required_files": [
    "README.md",
    "agentic-coding-policy.json",
    "specs/acceptance/acceptance_targets.md"
  ],
  "required_phrases": [
    {
      "file": "README.md",
      "phrase": "downstream ASH-based"
    }
  ],
  "forbidden_patterns": [
    {
      "pattern": "Aeostara core defines ASH semantics",
      "paths": ["README.md"]
    }
  ],
  "required_any_globs": [
    {
      "patterns": ["**/*.cpp", "**/*.cc", "**/*.cxx", "**/*.h", "**/*.hpp"],
      "min_total": 1
    }
  ]
}

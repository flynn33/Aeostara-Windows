{
  "profile": "main",
  "description": "Spec/conformance branch profile",
  "required_files": [
    "README.md",
    "REMEDIATION_STATUS.md",
    "specs/architecture/ash_authority_and_aeostara_conformance.md",
    "specs/acceptance/acceptance_targets.md",
    "specs/acceptance/traceability_matrix.md",
    "ci/validate_schemas.py",
    "ci/compliance_checker.py",
    "ci/acceptance_runner.py"
  ],
  "required_phrases": [
    {
      "file": "README.md",
      "phrase": "downstream ASH-based"
    },
    {
      "file": "REMEDIATION_STATUS.md",
      "phrase": "ASH is the immutable upstream semantic authority"
    }
  ],
  "forbidden_patterns": [
    {
      "pattern": "Aeostara core defines ASH semantics",
      "paths": ["README.md", "specs/architecture", "specs/acceptance"]
    },
    {
      "pattern": "ASH subsystem of Aeostara",
      "paths": ["README.md", "specs/architecture", "specs/acceptance"]
    }
  ],
  "required_globs": [
    {
      "pattern": "specs/contracts/*.schema.json",
      "min_count": 21
    },
    {
      "pattern": "specs/algorithms/*.pseudo.md",
      "min_count": 10
    }
  ],
  "forbidden_globs": [
    {
      "pattern": "**/*.swift"
    },
    {
      "pattern": "**/*.cpp"
    },
    {
      "pattern": "**/*.h"
    }
  ]
}
